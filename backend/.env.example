# Supabase credentials — use SERVICE ROLE key (not anon key)
# so the backend can bypass Row Level Security and insert freely
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Comma-separated list of allowed CORS origins.
# Default already includes localhost:5173, localhost:3000, and the Vercel URL.
# Override on Render if your frontend URL is different.
# ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:5173
